# ─── Entorno ───────────────────────────────────────────────
APP_NAME="Credinor"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/credinor2/public
APP_KEY=CAMBIA_ESTA_CLAVE_32_CHARS_RANDOM

# ─── Base de datos ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=credinor2
DB_USER=root
DB_PASS=

# ─── Sesión ────────────────────────────────────────────────
SESSION_LIFETIME=1800
SESSION_NAME=credinor_sess

# ─── Email (PHPMailer) ────────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@credinor.com.ar
MAIL_FROM_NAME="Credinor"

# ─── Timezone ──────────────────────────────────────────────
APP_TIMEZONE=America/Argentina/Tucuman

# ─── Contacto admin (cobrador mobile) ─────────────────────
# Número internacional sin + ni espacios (ej: 5493811234567)
ADMIN_WHATSAPP=
